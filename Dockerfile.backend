# syntax=docker/dockerfile:1
FROM node:22-slim AS base
RUN npm install -g pnpm
WORKDIR /app

# Install system deps needed for better-sqlite3 native build
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ \
    && rm -rf /var/lib/apt/lists/*

# ── deps stage ────────────────────────────────────────────────────────────────
FROM base AS deps
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY packages/shared/package.json ./packages/shared/
COPY packages/backend/package.json ./packages/backend/
# Only install backend + shared (skip desktop / Tauri)
RUN pnpm install --frozen-lockfile --filter @local-assistant/backend --filter @local-assistant/shared

# ── build stage ───────────────────────────────────────────────────────────────
FROM deps AS build
COPY packages/shared ./packages/shared
COPY packages/backend ./packages/backend
RUN pnpm --filter @local-assistant/shared build
RUN pnpm --filter @local-assistant/backend build

# ── runtime stage ─────────────────────────────────────────────────────────────
FROM node:22-slim AS runtime
RUN npm install -g pnpm
WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 make g++ \
    && rm -rf /var/lib/apt/lists/*

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY packages/shared/package.json ./packages/shared/
COPY packages/backend/package.json ./packages/backend/
RUN pnpm install --frozen-lockfile --filter @local-assistant/backend --filter @local-assistant/shared --prod

COPY --from=build /app/packages/shared/dist ./packages/shared/dist
COPY --from=build /app/packages/backend/dist ./packages/backend/dist

ENV PORT=3001
ENV NODE_ENV=production
# Reach host Ollama from inside the container
ENV OLLAMA_URL=http://host.docker.internal:11434

EXPOSE 3001

CMD ["node", "packages/backend/dist/index.js"]
